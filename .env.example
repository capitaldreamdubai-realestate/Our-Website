# Copy to `.env` and fill with your Supabase project (Settings → API).
# Vite only exposes variables prefixed with VITE_.

VITE_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
# Router mode for static hosting:
# - browser (default): requires server rewrite to index.html (see public/.htaccess)
# - hash: uses URLs like /#/route and works even without rewrites
VITE_ROUTER_MODE=browser

# Server-side only — for `npm run seed` (full CMS seed from repo data).
# Dashboard → Project Settings → API → service_role (secret).
# Never use the VITE_ prefix; never import this in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Property Finder: do NOT put PF_API_KEY / PF_API_SECRET here.
# Set them as Edge Function secrets for `sync-property-finder` (Dashboard → Edge Functions → Secrets).
