<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Keep existing files/directories accessible.
  RewriteCond %{REQUEST_FILENAME} -f [OR]
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]

  # Route all other paths to the SPA entry point.
  RewriteRule ^ index.html [L]
</IfModule>
